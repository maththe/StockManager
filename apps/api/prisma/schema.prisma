generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================= ENUMS =================

enum EventStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Define se a divergência foi porque sumiu ou porque quebrou
enum DivergenceType {
  MISSING
  DAMAGED
}

// Define se a divergência já foi resolvida (ex: cliente pagou pela cadeira quebrada)
enum DivergenceStatus {
  PENDING
  RESOLVED
}

// ================= MODELS =================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  items       Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Client {
  id          String   @id @default(uuid())
  companyName String
  taxId       String   @unique
  contactName String?
  events      Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Item {
  id                String   @id @default(uuid())
  skuCode           String   @unique
  name              String
  totalQuantity     Int      @default(0)
  availableQuantity Int      @default(0)
  unitCost          Decimal  @db.Decimal(10, 2)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  eventItems EventItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("items")
}

model Event {
  id            String      @id @default(uuid())
  eventName     String
  startDate     DateTime
  endDate       DateTime
  eventLocation String
  status        EventStatus @default(PLANNING)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  eventItems EventItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("events")
}

model EventItem {
  id               String   @id @default(uuid())
  plannedQuantity  Int
  shippedQuantity  Int      @default(0)
  returnedQuantity Int      @default(0)

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  divergences Divergence[] // Relacionamento com as divergências

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([itemId])
  @@map("event_items")
}

// NOVA TABELA: Divergências
model Divergence {
  id          String           @id @default(uuid())
  quantity    Int              // Quantidade que faltou ou quebrou
  type        DivergenceType   // MISSING (Faltou) ou DAMAGED (Danificado)
  status      DivergenceStatus @default(PENDING) // Começa como pendente de resolução
  notes       String?          // Observações (Ex: "Cadeira quebrou a perna traseira")

  eventItemId String
  eventItem   EventItem @relation(fields: [eventItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventItemId])
  @@map("divergences")
}