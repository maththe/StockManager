generator client {
  provider        = "prisma-client-js"
  }

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum EventStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Corrigido typo e adicionado status parciais caso decida manter
enum AllocationStatus {
  RESERVED
  IN_TRANSIT
  AT_EVENT
  PARTIALLY_RETURNED 
  RETURNED
  RETURNED_WITH_DAMAGE
  AVAILABLE
}

// NOVO: Tipo de movimentação
enum MovementType {
  STOCK_IN        // Compra/Adição de estoque
  STOCK_OUT       // Remoção/Baixa
  EVENT_DISPATCH  // Envio para evento
  EVENT_RETURN    // Retorno de evento
  DAMAGE_LOSS     // Perda ou quebra
  ADJUSTMENT      // Ajuste de inventário
}

// ================= MODELS =================

model User {
  id        String          @id @default(uuid())
  name      String
  email     String          @unique
  // Sugestão futura: adicionar role (ADMIN, MANAGER) e senha
  
  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  items       Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Client {
  id          String   @id @default(uuid())
  companyName String
  taxId       String   @unique // CNPJ/CPF
  contactName String?
  events      Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Item {
  id                String   @id @default(uuid())
  code           String   @unique
  name              String
  totalQuantity     Int      @default(0)
  availableQuantity Int      @default(0)
  unitCost          Decimal  @db.Decimal(10, 2)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  allocations EventAllocatedItem[]
  movements   StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId]) // Adicionado índice
  @@map("items")
}

model Event {
  id            String      @id @default(uuid())
  eventName     String
  startDate     DateTime
  endDate       DateTime
  eventLocation String
  status        EventStatus @default(PLANNING)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  allocatedItems EventAllocatedItem[]
  movements      StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId]) // Adicionado índice
  @@map("events")
}

model EventAllocatedItem {
  id               String           @id @default(uuid())
  plannedQuantity  Int
  shippedQuantity  Int              @default(0)
  returnedQuantity Int              @default(0)
  allocationStatus AllocationStatus @default(RESERVED)

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId]) // Adicionado índice
  @@index([itemId])  // Adicionado índice
  @@map("event_allocated_items")
}

model StockMovement {
  id           String       @id @default(uuid())
  quantity     Int          // Sempre positivo. O tipo define se soma ou subtrai
  movementType MovementType // NOVO: Define o contexto do movimento
  movementDate DateTime     @default(now())
  notes        String?

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
  @@index([userId])
  @@index([eventId])
  @@map("stock_movements")
}